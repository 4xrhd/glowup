# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=glowup

# Site Configuration
SITE_NAME=GlowUp Beauty
SITE_URL=https://yourdomain.com

# Admin Settings
